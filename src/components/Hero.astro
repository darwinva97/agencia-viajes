---
---

<section class="hero">
  <div class="hero-bg">
    <img src="https://images.unsplash.com/photo-1526392060635-9d6019884377?w=1920&q=80" alt="Machu Picchu al amanecer" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-badges">
      <span class="badge badge-white">🌟 +5,000 viajeros felices</span>
      <span class="badge badge-white">🏆 15 años de experiencia</span>
    </div>

    <h1>Descubre la magia<br />del <span class="text-accent">Perú</span></h1>
    <p class="hero-subtitle">Viajes únicos a Machu Picchu, Cusco, el Amazonas y más. Experiencias auténticas diseñadas por expertos locales.</p>

    <div class="search-bar">
      <div class="search-field">
        <label>📍 Destino</label>
        <select>
          <option>¿A dónde quieres ir?</option>
          <option>Cusco & Machu Picchu</option>
          <option>Lago Titicaca</option>
          <option>Amazonas</option>
          <option>Arequipa & Colca</option>
          <option>Líneas de Nazca</option>
          <option>Huacachina</option>
        </select>
      </div>
      <div class="search-field">
        <label>📅 Fecha</label>
        <input type="date" />
      </div>
      <div class="search-field">
        <label>👥 Viajeros</label>
        <select>
          <option>2 viajeros</option>
          <option>1 viajero</option>
          <option>3 viajeros</option>
          <option>4 viajeros</option>
          <option>5+ viajeros</option>
        </select>
      </div>
      <button class="btn btn-primary btn-search">🔍 Buscar</button>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <strong>200+</strong>
        <span>Tours disponibles</span>
      </div>
      <div class="stat">
        <strong>50+</strong>
        <span>Destinos</span>
      </div>
      <div class="stat">
        <strong>4.9 ★</strong>
        <span>Calificación</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll">
    <a href="#destinos">
      <span>Explorar</span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(30,58,95,.85) 0%, rgba(30,58,95,.5) 50%, rgba(146,64,14,.4) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding-top: 5rem;
  }
  .hero-badges {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .hero h1 {
    color: #fff;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    margin-bottom: 1.25rem;
    text-shadow: 0 2px 20px rgba(0,0,0,.3);
  }
  .text-accent { color: var(--accent-light); }
  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.3rem);
    max-width: 650px;
    margin: 0 auto 2.5rem;
    opacity: 0.92;
    line-height: 1.6;
  }
  .search-bar {
    display: flex;
    background: rgba(255,255,255,.97);
    border-radius: var(--radius);
    overflow: hidden;
    max-width: 850px;
    margin: 0 auto 3rem;
    box-shadow: var(--shadow-xl);
  }
  .search-field {
    flex: 1;
    padding: 1rem 1.25rem;
    border-right: 1px solid #e2e8f0;
    text-align: left;
  }
  .search-field label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-light);
    margin-bottom: 0.3rem;
  }
  .search-field select,
  .search-field input {
    border: none;
    font-size: 0.9rem;
    color: var(--text);
    font-family: 'Inter', sans-serif;
    width: 100%;
    background: transparent;
    cursor: pointer;
  }
  .search-field select:focus,
  .search-field input:focus { outline: none; }
  .btn-search {
    border-radius: 0;
    padding: 1rem 1.75rem;
    font-size: 1rem;
    white-space: nowrap;
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
  }
  .stat strong {
    display: block;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
  }
  .stat span {
    font-size: 0.85rem;
    opacity: 0.8;
  }
  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  .hero-scroll a {
    color: rgba(255,255,255,.7);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    animation: bounce 2s infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }
  @media (max-width: 768px) {
    .search-bar {
      flex-direction: column;
      border-radius: var(--radius);
    }
    .search-field { border-right: none; border-bottom: 1px solid #e2e8f0; }
    .hero-stats { gap: 1.5rem; }
    .stat strong { font-size: 1.3rem; }
  }
</style>
