---
const photos = [
  { src: 'https://images.unsplash.com/photo-1526392060635-9d6019884377?w=600&q=80', alt: 'Machu Picchu panorámica', span: 'span-2' },
  { src: 'https://images.unsplash.com/photo-1580399581268-478e4e4ae1f5?w=600&q=80', alt: 'Cóndor en el Colca', span: '' },
  { src: 'https://images.unsplash.com/photo-1516026672322-bc52d61a55d5?w=600&q=80', alt: 'Amazonía peruana', span: '' },
  { src: 'https://images.unsplash.com/photo-1580619305218-8423a7ef79b4?w=600&q=80', alt: 'Lago Titicaca', span: '' },
  { src: 'https://images.unsplash.com/photo-1531065208531-4036c0dba3ca?w=600&q=80', alt: 'Oasis de Huacachina', span: '' },
  { src: 'https://images.unsplash.com/photo-1551632811-561732d1e306?w=600&q=80', alt: 'Trekking en los Andes', span: 'span-2' },
  { src: 'https://images.unsplash.com/photo-1493246507139-91e8fad9978e?w=600&q=80', alt: 'Montaña de colores', span: '' },
  { src: 'https://images.unsplash.com/photo-1599499462209-5cf308ead061?w=600&q=80', alt: 'Líneas de Nazca', span: '' },
];
---

<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Galería</span>
      <h2>Imágenes que inspiran</h2>
      <p>Una muestra de los paisajes y experiencias que te esperan en Perú.</p>
    </div>

    <div class="gallery-grid">
      {photos.map(photo => (
        <div class={`gallery-item ${photo.span}`}>
          <img src={photo.src} alt={photo.alt} loading="lazy" />
          <div class="gallery-overlay">
            <span>{photo.alt}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }
  .gallery-item {
    position: relative;
    border-radius: var(--radius-sm);
    overflow: hidden;
    aspect-ratio: 1;
    cursor: pointer;
  }
  .gallery-item.span-2 {
    grid-column: span 2;
    aspect-ratio: 2/1;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .gallery-item:hover img {
    transform: scale(1.08);
  }
  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(30,58,95,.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .gallery-item:hover .gallery-overlay { opacity: 1; }
  .gallery-overlay span {
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    text-align: center;
    padding: 1rem;
  }
  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-item.span-2 { grid-column: span 2; }
  }
  @media (max-width: 480px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-item.span-2 { grid-column: span 1; aspect-ratio: 16/9; }
    .gallery-item { aspect-ratio: 16/10; }
  }
</style>
