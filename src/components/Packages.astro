---
const packages = [
  {
    name: 'Cusco Imperial',
    duration: '5 días / 4 noches',
    price: 599,
    image: 'https://images.unsplash.com/photo-1526392060635-9d6019884377?w=600&q=80',
    badge: 'Más popular',
    highlights: ['Machu Picchu con guía experto', 'Valle Sagrado de los Incas', 'City Tour por Cusco', 'Salineras de Maras y Moray'],
    includes: ['🏨 Hotel', '🍽️ Desayunos', '🚐 Transporte', '🎙️ Guía'],
    featured: true,
  },
  {
    name: 'Selva Amazónica',
    duration: '4 días / 3 noches',
    price: 449,
    image: 'https://images.unsplash.com/photo-1516026672322-bc52d61a55d5?w=600&q=80',
    badge: 'Aventura',
    highlights: ['Lodge en plena selva', 'Avistamiento de fauna silvestre', 'Visita a comunidades nativas', 'Caminata nocturna en la selva'],
    includes: ['🏨 Lodge', '🍽️ Pensión completa', '🚤 Transporte fluvial', '🎙️ Guía naturalista'],
    featured: false,
  },
  {
    name: 'Perú Completo',
    duration: '12 días / 11 noches',
    price: 1899,
    image: 'https://images.unsplash.com/photo-1580619305218-8423a7ef79b4?w=600&q=80',
    badge: 'Premium',
    highlights: ['Lima: gastronomía y cultura', 'Cusco & Machu Picchu', 'Lago Titicaca & islas flotantes', 'Arequipa & Cañón del Colca'],
    includes: ['🏨 Hoteles 4★', '🍽️ Desayunos y cenas', '✈️ Vuelos internos', '🎙️ Guías bilingües'],
    featured: false,
  },
];
---

<section class="section bg-alt" id="paquetes">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Paquetes de Viaje</span>
      <h2>Paquetes diseñados para ti</h2>
      <p>Experiencias completas con todo incluido. Solo tienes que elegir tu aventura.</p>
    </div>

    <div class="packages-grid">
      {packages.map(pkg => (
        <div class={`card pkg-card ${pkg.featured ? 'featured' : ''}`}>
          <div class="card-img">
            <img src={pkg.image} alt={pkg.name} loading="lazy" />
            <span class={`badge ${pkg.featured ? 'badge-accent' : 'badge-white'} pkg-badge`}>{pkg.badge}</span>
          </div>
          <div class="card-body">
            <h3>{pkg.name}</h3>
            <p class="pkg-duration">🗓️ {pkg.duration}</p>

            <ul class="pkg-highlights">
              {pkg.highlights.map(h => (
                <li>{h}</li>
              ))}
            </ul>

            <div class="pkg-includes">
              {pkg.includes.map(inc => (
                <span class="pkg-include-item">{inc}</span>
              ))}
            </div>

            <div class="pkg-footer">
              <div>
                <span class="price-label">Desde</span>
                <span class="price pkg-price">${pkg.price}</span>
                <span class="price-label">/ persona</span>
              </div>
              <a href="/#contacto" class="btn btn-primary">Reservar</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .packages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-items: start;
  }
  .pkg-card.featured {
    border: 2px solid var(--accent);
    transform: scale(1.03);
  }
  .pkg-card.featured:hover { transform: scale(1.05); }
  .pkg-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
  }
  .pkg-duration {
    color: var(--text-light);
    font-size: 0.9rem;
    margin: 0.5rem 0 1rem;
  }
  .pkg-highlights {
    margin-bottom: 1.25rem;
  }
  .pkg-highlights li {
    padding: 0.35rem 0;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text);
  }
  .pkg-highlights li::before {
    content: '✓';
    color: var(--success);
    font-weight: 700;
    flex-shrink: 0;
  }
  .pkg-includes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid #f1f5f9;
  }
  .pkg-include-item {
    font-size: 0.8rem;
    padding: 0.25rem 0.6rem;
    background: var(--bg-alt);
    border-radius: 50px;
  }
  .pkg-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid #f1f5f9;
  }
  .pkg-price { font-size: 1.5rem; }
  @media (max-width: 900px) {
    .packages-grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; }
    .pkg-card.featured { transform: none; }
  }
</style>
