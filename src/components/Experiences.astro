---
const experiences = [
  {
    emoji: '🏔️',
    title: 'Trekking y Aventura',
    description: 'Camino Inca, Salkantay, Ausangate y más rutas épicas por los Andes peruanos.',
    image: 'https://images.unsplash.com/photo-1551632811-561732d1e306?w=600&q=80',
  },
  {
    emoji: '🏛️',
    title: 'Cultural e Histórico',
    description: 'Explora civilizaciones milenarias, templos incas y tradiciones vivas del Perú.',
    image: 'https://images.unsplash.com/photo-1580619305218-8423a7ef79b4?w=600&q=80',
  },
  {
    emoji: '🍽️',
    title: 'Gastronomía',
    description: 'Ceviche, lomo saltado, pisco sour. La mejor cocina de Latinoamérica te espera.',
    image: 'https://images.unsplash.com/photo-1535399831218-d5bd36d1a6b3?w=600&q=80',
  },
  {
    emoji: '🌿',
    title: 'Ecoturismo',
    description: 'Amazonía, reservas naturales y biodiversidad única en el mundo.',
    image: 'https://images.unsplash.com/photo-1516026672322-bc52d61a55d5?w=600&q=80',
  },
  {
    emoji: '📸',
    title: 'Fotografía',
    description: 'Tours fotográficos por paisajes de ensueño: montañas, lagunas turquesa y más.',
    image: 'https://images.unsplash.com/photo-1493246507139-91e8fad9978e?w=600&q=80',
  },
  {
    emoji: '🧘',
    title: 'Bienestar y Wellness',
    description: 'Retiros de yoga, baños termales y ceremonias ancestrales de sanación.',
    image: 'https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=600&q=80',
  },
];
---

<section class="section" id="experiencias">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Tipos de Experiencia</span>
      <h2>¿Qué tipo de viajero eres?</h2>
      <p>Tenemos la experiencia perfecta para cada estilo de viaje.</p>
    </div>

    <div class="exp-grid">
      {experiences.map(exp => (
        <a href="/destinos" class="exp-card">
          <div class="exp-bg">
            <img src={exp.image} alt={exp.title} loading="lazy" />
            <div class="exp-overlay"></div>
          </div>
          <div class="exp-content">
            <span class="exp-emoji">{exp.emoji}</span>
            <h3>{exp.title}</h3>
            <p>{exp.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .exp-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .exp-card {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4/3;
    display: flex;
    align-items: flex-end;
    cursor: pointer;
  }
  .exp-bg {
    position: absolute;
    inset: 0;
  }
  .exp-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .exp-card:hover .exp-bg img {
    transform: scale(1.1);
  }
  .exp-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(30,58,95,.9) 0%, rgba(30,58,95,.2) 60%, transparent 100%);
  }
  .exp-content {
    position: relative;
    z-index: 2;
    padding: 1.5rem;
    color: #fff;
  }
  .exp-emoji { font-size: 2rem; display: block; margin-bottom: 0.5rem; }
  .exp-content h3 {
    color: #fff;
    font-size: 1.15rem;
    margin-bottom: 0.4rem;
  }
  .exp-content p {
    font-size: 0.85rem;
    opacity: 0.85;
    line-height: 1.5;
  }
  @media (max-width: 900px) {
    .exp-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .exp-grid { grid-template-columns: 1fr; }
  }
</style>
